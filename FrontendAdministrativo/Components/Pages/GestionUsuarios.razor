@page "/gestion-usuarios"
@rendermode InteractiveServer
@using FrontendAdministrativo.Models

<PageTitle>Gestión de Usuarios</PageTitle>

<div class="panel">

    <div class="panel-header">
        <div>
            <h1>Gestión de Usuarios</h1>
            <p>Administra los roles asignados a cada usuario.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(mensaje))
    {
        <div class="alert alert-success mb-4" role="alert">
            @mensaje
        </div>
    }

    <div class="panel-card">

        <table class="usuarios-table">

            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Rol actual</th>
                    <th>Nuevo rol</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var usuario in usuarios)
                {
                    <tr>

                        <td class="user-name">
                            @usuario.Nombre
                        </td>

                        <td>
                            <span class="badge @RolClase(usuario.Rol)">
                                @usuario.Rol
                            </span>
                        </td>

                        <td>
                            <select class="rol-select"
                                    @bind="rolSeleccionado[usuario.Id]">

                                <option value="Administrador">Administrador</option>
                                <option value="Usuario">Usuario</option>
                                <option value="Invitado">Invitado</option>

                            </select>
                        </td>

                        <td class="text-center">

                            <button class="btn-guardar"
                                    @onclick="() => GuardarRol(usuario)">
                                Actualizar rol
                            </button>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@code {

    private List<Usuario> usuarios = new()
    {
        new Usuario
        {
            Id = 1,
            Nombre = "Jonathan Sánchez",
            Rol = "Administrador"
        },

        new Usuario
        {
            Id = 2,
            Nombre = "María López",
            Rol = "Usuario"
        },

        new Usuario
        {
            Id = 3,
            Nombre = "Carlos Pérez",
            Rol = "Usuario"
        },

        new Usuario
        {
            Id = 4,
            Nombre = "Andrea García",
            Rol = "Invitado"
        }
    };

    private Dictionary<int, string> rolSeleccionado = new();

    private string mensaje = "";

    protected override void OnInitialized()
    {
        rolSeleccionado = usuarios.ToDictionary(u => u.Id, u => u.Rol);
    }

    private void GuardarRol(Usuario usuario)
    {
        if (!rolSeleccionado.ContainsKey(usuario.Id))
        {
            mensaje = "No se pudo actualizar el rol.";
            return;
        }

        usuario.Rol = rolSeleccionado[usuario.Id];

        mensaje = $"El rol de {usuario.Nombre} fue actualizado correctamente a {usuario.Rol}.";
    }

    private string RolClase(string rol)
    {
        return rol switch
        {
            "Administrador" => "badge-administrador",
            "Usuario" => "badge-usuario",
            "Invitado" => "badge-invitado",
            _ => "badge-usuario"
        };
    }

}