@page "/reportes"
@rendermode InteractiveServer
@using FrontendAdministrativo.Models
@inject FrontendAdministrativo.Services.UtnGolCoinApiService Api

<PageTitle>Reportes</PageTitle>

<div class="admin-header">
    <div class="admin-header-title">
        <h1>Reportes</h1>
        <p>Estadísticas reales del sistema UTNGolCoin.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-@tipoMensaje mb-3" role="alert">@mensaje</div>
}

@if (cargando)
{
    <p>Cargando reportes...</p>
}
else
{
    <div class="admin-header-stats" style="margin-bottom: 1.5rem;">
        <div class="admin-stat">
            <span class="admin-stat-num">@(monedas?.TotalMonedasEnCirculacion.ToString("N2") ?? "-")</span>
            <span class="admin-stat-label">UTNGolCoin en circulación</span>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-num">@(monedas?.CantidadBilleteras.ToString() ?? "-")</span>
            <span class="admin-stat-label">Billeteras</span>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-num">@(monedas?.TotalPagadoEnPremios.ToString("N2") ?? "-")</span>
            <span class="admin-stat-label">Pagado en premios</span>
        </div>
    </div>

    <h3>Partidos con más predicciones</h3>
    @if (partidos.Count == 0)
    {
        <p>No hay datos de predicciones.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Partido</th>
                    <th>Predicciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in partidos)
                {
                    <tr>
                        <td>Partido #@p.PartidoId</td>
                        <td>@p.CantidadPredicciones</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private MonedasCirculacionDto? monedas;
    private List<PartidoApostadoDto> partidos = new();
    private bool cargando = true;
    private string mensaje = "";
    private string tipoMensaje = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            monedas = await Api.ObtenerMonedasCirculacion();
            partidos = await Api.ObtenerPartidosMasApostados(top: 5);
        }
        catch (Exception ex)
        {
            mensaje = $"No se pudo conectar con UTNGolCoin: {ex.Message}";
            tipoMensaje = "danger";
        }
        finally
        {
            cargando = false;
        }
    }
}