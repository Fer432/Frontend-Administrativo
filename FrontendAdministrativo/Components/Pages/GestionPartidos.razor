@page "/gestion-partidos"
@rendermode InteractiveServer
@using FrontendAdministrativo.Models

<PageTitle>Gestión de Partidos</PageTitle>
<div class="admin-header">
    <div class="admin-header-title">
        <h1>Gestión de Partidos</h1>
        <p>Administra los encuentros, registra resultados y controla su estado.</p>
    </div>
    <div class="admin-header-stats">
        <div class="admin-stat">
            <span class="admin-stat-num">@partidos.Count</span>
            <span class="admin-stat-label">Total</span>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-num">@partidos.Count(p => p.Estado == "Programado")</span>
            <span class="admin-stat-label">Programados</span>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-num">@partidos.Count(p => p.Estado == "Finalizado")</span>
            <span class="admin-stat-label">Finalizados</span>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-@tipoMensaje mb-3" role="alert">@mensaje</div>
}

@code {

    private List<Partido> partidos = new()
    {
        new Partido
        {
            Id = 1,
            Local = "🇪🇨 Ecuador",
            Visitante = "🇧🇷 Brasil",
            Fecha = new DateTime(2026, 7, 22, 18, 0, 0),
            Sede = "MetLife Stadium",
            GolesLocal = 0,
            GolesVisitante = 0,
            Estado = "Programado"
        },

        new Partido
        {
            Id = 2,
            Local = "🇦🇷 Argentina",
            Visitante = "🇺🇾 Uruguay",
            Fecha = new DateTime(2026, 7, 23, 20, 30, 0),
            Sede = "Estadio Azteca",
            GolesLocal = 0,
            GolesVisitante = 0,
            Estado = "Programado"
        },

        new Partido
        {
            Id = 3,
            Local = "🇪🇸 España",
            Visitante = "🇩🇪 Alemania",
            Fecha = new DateTime(2026, 7, 20, 16, 0, 0),
            Sede = "SoFi Stadium",
            GolesLocal = 2,
            GolesVisitante = 1,
            Estado = "Finalizado"
        }
    };

    private string mensaje = "";
    private string tipoMensaje = "";

    private int? editandoId = null;

    private string formLocal = "";
    private string formVisitante = "";
    private DateTime formFecha = DateTime.Now;
    private string formSede = "";

    private void MostrarMensaje(string texto, string tipo)
    {
        mensaje = texto;

        tipoMensaje = tipo switch
        {
            "success" => "success",
            "danger" => "danger",
            "warning" => "warning",
            _ => "primary"
        };
    }
    

    private void GuardarPartido()
    {
        if (string.IsNullOrWhiteSpace(formLocal) ||
            string.IsNullOrWhiteSpace(formVisitante) ||
            string.IsNullOrWhiteSpace(formSede))
        {
            MostrarMensaje(
                "Debe completar Local, Visitante y Sede.",
                "warning");

            return;
        }

        if (editandoId is null)
        {
            int nuevoId = partidos.Any() ? partidos.Max(p => p.Id) + 1 : 1;

            partidos.Add(new Partido
            {
                Id = nuevoId,
                Local = formLocal,
                Visitante = formVisitante,
                Fecha = formFecha,
                Sede = formSede,
                GolesLocal = 0,
                GolesVisitante = 0,
                Estado = "Programado"
            });

            MostrarMensaje(
                "Partido creado correctamente.",
                "success");
        }
        else
        {
            var partido = partidos.FirstOrDefault(p => p.Id == editandoId);

            if (partido != null)
            {
                partido.Local = formLocal;
                partido.Visitante = formVisitante;
                partido.Fecha = formFecha;
                partido.Sede = formSede;

                MostrarMensaje(
                    "Partido actualizado correctamente.",
                    "success");
            }
        }

        LimpiarFormulario();
    }

    private void IniciarEdicion(Partido partido)
    {
        editandoId = partido.Id;
        formLocal = partido.Local;
        formVisitante = partido.Visitante;
        formFecha = partido.Fecha;
        formSede = partido.Sede;
    }

    private void CancelarEdicion()
    {
        LimpiarFormulario();
    }

    private void LimpiarFormulario()
    {
        editandoId = null;
        formLocal = "";
        formVisitante = "";
        formFecha = DateTime.Now;
        formSede = "";
    }

    private void RegistrarResultado(Partido partido)
    {
        if (partido.Estado == "Finalizado")
        {
            MostrarMensaje(
                "Este partido ya fue finalizado.",
                "danger");

            return;
        }

        partido.Estado = "Finalizado";

        MostrarMensaje(
            $"Resultado registrado: {partido.Local} {partido.GolesLocal} - {partido.GolesVisitante} {partido.Visitante}.",
            "success");
    }

    private string EstadoClase(string estado)
    {
        return estado switch
        {
            "Finalizado" => "badge-finalizado",
            "En curso" => "badge-en-curso",
            _ => "badge-programado"
        };
    }

}