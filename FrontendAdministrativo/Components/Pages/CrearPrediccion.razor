@page "/crear-prediccion"
@rendermode InteractiveServer
@using FrontendAdministrativo.Models
@inject FrontendAdministrativo.Services.UtnGolCoinApiService Api

<PageTitle>Crear Predicción</PageTitle>

<div class="admin-header">
    <div class="admin-header-title">
        <h1>Crear Predicción</h1>
        <p>Registra una predicción en el sistema UTNGolCoin.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-@tipoMensaje">@mensaje</div>
}

<div style="max-width: 480px;">

    <div class="mb-3">
        <label class="form-label">ID de usuario</label>
        <input type="number" class="form-control" @bind="req.UsuarioId" />
    </div>

    <div class="mb-3">
        <label class="form-label">ID del partido</label>
        <input type="number" class="form-control" @bind="req.PartidoId" />
    </div>

    <div class="mb-3">
        <label class="form-label">Fecha de inicio del partido</label>
        <input type="datetime-local" class="form-control" @bind="req.FechaInicioPartido" />
        <small class="text-muted">Debe ser una fecha futura, o el backend rechaza la apuesta.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Pronóstico</label>
        <select class="form-select" @bind="req.Pronostico">
            <option value="LOCAL">LOCAL (cuota 2.0)</option>
            <option value="EMPATE">EMPATE (cuota 3.0)</option>
            <option value="VISITANTE">VISITANTE (cuota 2.5)</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Monto</label>
        <input type="number" step="0.01" class="form-control" @bind="req.Monto" />
    </div>

    <button class="btn btn-primary" @onclick="Guardar" disabled="@procesando">
        @(procesando ? "Guardando..." : "Crear predicción")
    </button>

</div>

@code {
    private CrearPrediccionRequestDto req = new()
    {
        UsuarioId = 100,
        PartidoId = 1,
        FechaInicioPartido = DateTime.Now.AddDays(7),
        Pronostico = "LOCAL",
        Monto = 1
    };

    private bool procesando = false;
    private string mensaje = "";
    private string tipoMensaje = "";

    private async Task Guardar()
    {
        mensaje = "";
        procesando = true;
        try
        {
            var (ok, error) = await Api.CrearPrediccion(req);
            if (ok)
            {
                mensaje = "Predicción creada correctamente.";
                tipoMensaje = "success";
            }
            else
            {
                mensaje = $"No se pudo crear: {error}";
                tipoMensaje = "danger";
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error de conexión: {ex.Message}";
            tipoMensaje = "danger";
        }
        finally
        {
            procesando = false;
        }
    }
}