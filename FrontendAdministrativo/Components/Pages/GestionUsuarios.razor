@page "/gestion-usuarios"
@rendermode InteractiveServer
@using FrontendAdministrativo.Models
@inject FrontendAdministrativo.Services.EstadisticasApiService Api
@inject FrontendAdministrativo.Services.SesionAdmin Sesion

<PageTitle>Gestión de Usuarios</PageTitle>

<div class="panel">

    <div class="panel-header">
        <div>
            <h1>Gestión de Usuarios</h1>
            <p>Administra los roles asignados a cada usuario.</p>
        </div>
    </div>

    @if (!Sesion.EstaAutenticado)
    {
        <div class="alert alert-warning">
            Debes iniciar sesión como administrador para ver y gestionar usuarios.
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(mensaje))
        {
            <div class="alert alert-@tipoMensaje mb-4">@mensaje</div>
        }

        <div class="panel-card">
            <table class="usuarios-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Rol actual</th>
                        <th>Nuevo rol</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in usuarios)
                    {
                        <tr>
                            <td class="user-name">@u.Email</td>
                            <td><span class="badge @RolClase(u.Rol)">@u.Rol</span></td>
                            <td>
                                <select class="rol-select" @bind="rolSeleccionado[u.IdUsuario]">
                                    <option value="ADMINISTRADOR">ADMINISTRADOR</option>
                                    <option value="USUARIO_REGISTRADO">USUARIO_REGISTRADO</option>
                                    <option value="INVITADO">INVITADO</option>
                                </select>
                            </td>
                            <td class="text-center">
                                <button class="btn-guardar" @onclick="() => GuardarRol(u)">
                                    Actualizar rol
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private List<UsuarioDto> usuarios = new();
    private Dictionary<int, string> rolSeleccionado = new();
    private string mensaje = "";
    private string tipoMensaje = "";

    protected override async Task OnInitializedAsync()
    {
        if (Sesion.EstaAutenticado) await Cargar();
    }

    private async Task Cargar()
    {
        try
        {
            usuarios = await Api.ListarUsuarios();
            rolSeleccionado = usuarios.ToDictionary(u => u.IdUsuario, u => u.Rol);
        }
        catch (Exception ex)
        {
            mensaje = $"Error: {ex.Message}";
            tipoMensaje = "danger";
        }
    }

    private async Task GuardarRol(UsuarioDto usuario)
    {
        var nuevoRol = rolSeleccionado[usuario.IdUsuario];
        var (ok, error) = await Api.CambiarRol(usuario.IdUsuario, nuevoRol);

        mensaje = ok
            ? $"El rol de {usuario.Email} fue actualizado a {nuevoRol}."
            : $"No se pudo actualizar: {error}";
        tipoMensaje = ok ? "success" : "danger";

        if (ok) await Cargar();
    }

    private string RolClase(string rol) => rol switch
    {
        "ADMINISTRADOR" => "badge-administrador",
        "USUARIO_REGISTRADO" => "badge-usuario",
        "INVITADO" => "badge-invitado",
        _ => "badge-usuario"
    };
}