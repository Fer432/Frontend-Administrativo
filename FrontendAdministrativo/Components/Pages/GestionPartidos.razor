@page "/gestion-partidos"
@rendermode InteractiveServer
@using FrontendAdministrativo.Models
@inject FrontendAdministrativo.Services.EstadisticasApiService Api

<PageTitle>Gestión de Partidos</PageTitle>
<div class="admin-header">
    <div class="admin-header-title">
        <h1>Gestión de Partidos</h1>
        <p>Consulta los encuentros del Mundial y su fase.</p>
    </div>
    <div class="admin-header-stats">
        <div class="admin-stat">
            <span class="admin-stat-num">@partidos.Count</span>
            <span class="admin-stat-label">Total</span>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-num">@partidos.Count(p => p.Fase == "Grupo")</span>
            <span class="admin-stat-label">Fase de Grupos</span>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-num">@partidos.Count(p => p.Fase == "Final")</span>
            <span class="admin-stat-label">Final</span>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-@tipoMensaje mb-3" role="alert">@mensaje</div>
}

@if (cargando)
{
    <p>Cargando partidos...</p>
}
else if (partidos.Count == 0)
{
    <p>No hay partidos para mostrar.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Local</th>
                <th>Visitante</th>
                <th>Sede</th>
                <th>Fecha</th>
                <th>Fase</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in partidos)
            {
                <tr>
                    <td>@p.IdPartido</td>
                    <td>@p.SeleccionLocal</td>
                    <td>@p.SeleccionVisitante</td>
                    <td>@p.Sede</td>
                    <td>@p.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@p.Fase</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<PartidoDto> partidos = new();
    private bool cargando = true;
    private string mensaje = "";
    private string tipoMensaje = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            partidos = await Api.ListarPartidos();
        }
        catch (Exception ex)
        {
            mensaje = $"No se pudo conectar con el backend: {ex.Message}";
            tipoMensaje = "danger";
        }
        finally
        {
            cargando = false;
        }
    }
}