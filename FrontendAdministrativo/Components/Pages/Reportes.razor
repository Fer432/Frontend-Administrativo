@page "/reportes"

<PageTitle>Reportes</PageTitle>

<div class="container-fluid">

    <div class="mb-4">
        <h1>📊 Reportes del Sistema</h1>
        <p class="text-muted">
            Estadísticas generales del Mundial UTNGolMundial 2026.
        </p>
    </div>

    <!-- Tarjetas -->

    <div class="row g-4 mb-5">

        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h6>💰 UTNGolCoin</h6>
                <h2>@totalCoins.ToString("N0")</h2>
                <small class="text-muted">En circulación</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h6>⚽ Partidos</h6>
                <h2>@partidosConMasPredicciones.Count</h2>
                <small class="text-muted">Analizados</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h6>📈 Predicciones</h6>
                <h2>1,116</h2>
                <small class="text-muted">Registradas</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-4 text-center">
                <h6>📝 Auditorías</h6>
                <h2>@auditoria.Count</h2>
                <small class="text-muted">Eventos</small>
            </div>
        </div>

    </div>

    <!-- Partidos -->

    <div class="card p-4 mb-5">

        <h3 class="mb-3">🏆 Partidos con más predicciones</h3>

        <table class="table table-hover">

            <thead>

                <tr>

                    <th>Partido</th>

                    <th class="text-center">Predicciones</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in partidosConMasPredicciones)
                {
                    <tr>

                        <td>@item.Partido</td>

                        <td class="text-center fw-bold">

                            @item.NumeroPredicciones

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- Auditoría -->

    <div class="card p-4">

        <h3 class="mb-3">📋 Auditoría del sistema</h3>

        <table class="table table-hover">

            <thead>

                <tr>

                    <th>Fecha</th>

                    <th>Acción</th>

                    <th>Detalle</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var evento in auditoria)
                {
                    <tr>

                        <td>@evento.Fecha.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>

                            <span class="badge @AccionClase(evento.Accion)">

                                @evento.Accion

                            </span>

                        </td>

                        <td>@evento.Detalle</td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

    @code {

        private long totalCoins = 1_284_500;

        private record PartidoPredicciones(string Partido, int NumeroPredicciones);

        private List<PartidoPredicciones> partidosConMasPredicciones = new()
    {
        new("🇪🇨 Ecuador vs 🇧🇷 Brasil", 342),
        new("🇦🇷 Argentina vs 🇺🇾 Uruguay", 298),
        new("🇪🇸 España vs 🇩🇪 Alemania", 271),
        new("🇫🇷 Francia vs 🏴 Inglaterra", 205)
    };

        private record EventoAuditoria(
            DateTime Fecha,
            string Accion,
            string Detalle);

        private List<EventoAuditoria> auditoria = new()
    {
        new(DateTime.Now.AddHours(-2),
            "Registro de resultado",
            "Ecuador 2 - 1 Brasil"),

        new(DateTime.Now.AddHours(-5),
            "Cambio de rol",
            "María López fue promovida a Administrador"),

        new(DateTime.Now.AddDays(-1),
            "Registro de resultado",
            "Argentina 1 - 1 Uruguay"),

        new(DateTime.Now.AddDays(-2),
            "Cambio de rol",
            "Carlos Pérez pasó a Usuario")
    };

        private string AccionClase(string accion)
        {
            return accion switch
            {
                "Registro de resultado" => "badge-success",
                "Cambio de rol" => "badge-warning",
                _ => "badge-danger"
            };
        }

    }