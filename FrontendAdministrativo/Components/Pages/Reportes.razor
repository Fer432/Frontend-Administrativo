@page "/reportes"

<PageTitle>Reportes</PageTitle>

<div class="panel">
    <div class="panel-header">
        <div>
            <h1>Reportes</h1>
            <p>Panel de control con indicadores generales del sistema.</p>
        </div>
    </div>

    <div class="stat-card">
        <span class="stat-label">Total de UTNGolCoin en circulación</span>
        <span class="stat-value">@totalCoins.ToString("N0")</span>
    </div>

    <div class="section">
        <h2>Partidos con más predicciones</h2>
        <div class="panel-card">
            <table class="reportes-table">
                <thead>
                    <tr>
                        <th>Partido</th>
                        <th class="text-center">Número de predicciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in partidosConMasPredicciones)
                    {
                        <tr>
                            <td class="team-name">@item.Partido</td>
                            <td class="text-center">@item.NumeroPredicciones.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="section">
        <h2>Auditoría</h2>
        <div class="panel-card">
            <table class="reportes-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Acción</th>
                        <th>Detalle</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evento in auditoria)
                    {
                        <tr>
                            <td>@evento.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge @AccionClase(evento.Accion)">@evento.Accion</span></td>
                            <td>@evento.Detalle</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private long totalCoins = 1_284_500;

    private record PartidoPredicciones(string Partido, int NumeroPredicciones);

    private List<PartidoPredicciones> partidosConMasPredicciones = new()
    {
        new("Deportivo Norte vs Atlético Sur", 342),
        new("Real Central vs Unión Costa", 298),
        new("Estrella Azul vs Club Andino", 271),
        new("Ciudad Nueva vs Los Halcones", 205),
    };

    private record EventoAuditoria(DateTime Fecha, string Accion, string Detalle);

    private List<EventoAuditoria> auditoria = new()
    {
        new(new DateTime(2026, 7, 22, 9, 15, 0), "Registro de resultado", "Estrella Azul 2 - 1 Club Andino registrado por admin Ana Torres."),
        new(new DateTime(2026, 7, 21, 17, 40, 0), "Cambio de rol", "Luis Méndez pasó de Invitado a Usuario."),
        new(new DateTime(2026, 7, 21, 11, 5, 0), "Cambio de rol", "Carla Ruiz pasó de Usuario a Invitado."),
        new(new DateTime(2026, 7, 20, 20, 30, 0), "Registro de resultado", "Ciudad Nueva 0 - 0 Los Halcones registrado por admin Jorge Salas."),
    };

    private string AccionClase(string accion) => accion switch
    {
        "Registro de resultado" => "badge-resultado",
        "Cambio de rol" => "badge-rol",
        _ => "badge-otro"
    };
}
